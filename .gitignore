# Dart / Flutter
# ================================

# Dart tool cache
.dart_tool/
.pub-cache/
.pub/

# Flutter build output
build/

# Flutter/Dart package config
.packages
.flutter-plugins
.flutter-plugins-dependencies
pubspec.lock

# Flutter generated files
*.g.dart
*.freezed.dart
